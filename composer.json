{
  "name": "gerttimmerman/statamic-zapier",
  "description": "Statamic Zapier",
  "autoload": {
    "psr-4": {
      "GertTimmerman\\StatamicZapier\\": "src"
    }
  },
  "authors": [
    {
      "name": "Gert Timmerman"
    },
    {
      "name": "Michael Utz"
    }
  ],
  "support": {
    "email": "mike.u@delegator.com"
  },
  "extra": {
    "statamic": {
      "name": "Statamic Zapier",
      "description": "Push form submissions to Zapier webhooks"
    },
    "laravel": {
      "providers": [
        "GertTimmerman\\StatamicZapier\\ServiceProvider"
      ]
    }
  },
  "require": {
    "guzzlehttp/guzzle": "^7.0",
    "statamic/cms": "^6.0"
  },
  "config": {
    "allow-plugins": {
      "pixelfear/composer-dist-plugin": true
    }
  }
}
